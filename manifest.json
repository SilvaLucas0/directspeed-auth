{
  "manifest_version": 3,
  "name": "DirectSpeed",
  "version": "2.4.0",
  "description": "Automação de DMs no Instagram.",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DirectSpeed"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["panel.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],

  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "activeTab"
  ],

  "host_permissions": [
    "https://www.instagram.com/*",
    "https://directspeed-auth.onrender.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches":   ["https://www.instagram.com/*"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
